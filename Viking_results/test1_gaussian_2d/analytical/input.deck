# =====================================================================
# Test 1 (2D) — Gaussian beam, PROFILE-ONLY comparison: ANALYTICAL run
# ---------------------------------------------------------------------
# Milestone 1: show that the custom .dat injector reproduces EPOCH's
# native analytical Gaussian profile. This run uses the standard
# profile = gauss(y, 0, w_bnd); the matching "numerical" run injects the
# same envelope from a .dat file. Both use the SAME analytical paraxial
# phase, so this isolates the amplitude/profile injection path.
#
# Viking upgrade vs the laptop version: 50 cells per wavelength
# (nx=1750, ny=1250) instead of 20. To rescale resolution, change the
# "cells per micron" implicit in nx/ny below (box is 35 µm x 25 µm).
# =====================================================================

begin:constant

  lambda0 = 1.0 * micron
  pulse_FWHM = 2 * micron
  pulse_tau = 15 * femto                 # pulse duration (sigma)

  w_0 = pulse_FWHM / 1.665               # beam waist at focus

  intens = 1e22                          # W/cm^2
  a0 = 8.5e-4 * sqrt(intens * lambda0^2)

  # Beam focus 10 µm downstream of the x_min injection boundary
  pulse_defocus = 10 * micron
  x_spot = pulse_defocus

  # Derived beam parameters at the x_min boundary
  x_R = pi * w_0^2 / lambda0             # Rayleigh range
  RC = x_spot * (1.0 + (x_R/x_spot)^2)   # radius of curvature at boundary
  w_bnd = w_0 * sqrt( 1.0 + (x_spot/x_R)^2)  # spot size at boundary
  gouy = atan(x_spot/x_R)                # Gouy phase at boundary
end:constant

begin:control
  # 50 cells per wavelength (box: x in [-20,15] um = 35 um, y in [-12.5,12.5] = 25 um)
  nx = 1750
  ny = 1250

  nsteps = -1
  t_end = 200 * femto

  x_min = -20 * micro
  x_max = 15 * micro
  y_min = -12.5 * micro
  y_max = 12.5 * micro

  dt_multiplier = 0.9
  dlb_threshold = 0.8
  use_random_seed = T
  stdout_frequency = 100
end:control

begin:boundaries
  bc_x_min = simple_laser
  bc_x_max = open
  bc_y_min = open
  bc_y_max = open
end:boundaries

begin:laser
  boundary = x_min
  intensity_w_cm2 = intens * (w_0 / w_bnd)^2
  lambda = lambda0

  phase = 2.0 * pi / lambda0 * y^2 / (2.0 * RC) - gouy
  pol = 0

  # Native analytical Gaussian spatial profile + analytical temporal envelope
  use_custom_profile = F
  profile = gauss(y, 0, w_bnd)
  t_profile = gauss(time, 3*pulse_tau, pulse_tau)
  t_start = 0
  t_end = 6*pulse_tau
end:laser

begin:subset
  name = Defect_Region
  x_min = 10 * micron
  x_max = 15 * micron
  y_min = -7 * micron
  y_max = 7 * micron
end:subset

begin:output
  use_offset_grid = F
  dt_snapshot = 10.0e-15
  full_dump_every = -1
  force_final_to_be_restartable = F
  force_first_to_be_restartable = F

  # Grid fields (particles disabled — this is a vacuum field-injection test)
  grid = always
  ex = always
  ey = always + Defect_Region
  bz = always
  poynt_flux = always
  total_energy_sum = always
end:output

# =====================================================================
# Test 3 (3D) — Gaussian beam, PROFILE-ONLY comparison: NUMERICAL run
# ---------------------------------------------------------------------
# Same beam as the analytical 3D run, but the 2D (y,z) spatial profile is
# injected from spatial_profile.dat via the custom injector
# (use_spatiotemporal_profile = F: spatial-only, temporal handled by
# t_profile). Should reproduce gauss(y,0,w0)*gauss(z,0,w0) within
# interpolation tolerance.
# Generate the .dat first:  python generate_profile.py
# =====================================================================

begin:control
  nx = 300
  ny = 480
  nz = 480

  x_min = -5 * micron
  x_max = -x_min
  y_min = -8 * micron
  y_max = -y_min
  z_min = -8 * micron
  z_max = -z_min

  t_end = 50 * femto
  stdout_frequency = 10
end:control

begin:boundaries
  bc_x_min = simple_laser
  bc_x_max = open
  bc_y_min = periodic
  bc_y_max = periodic
  bc_z_min = periodic
  bc_z_max = periodic
end:boundaries

begin:constant
  lambda0 = 1 * micron
  w0 = 3 * micron
end:constant

begin:laser
  boundary = x_min
  intensity_w_cm2 = 1.0e20
  lambda = lambda0

  # Custom 2D (y,z) spatial profile read from spatial_profile.dat
  use_custom_profile = T
  use_spatiotemporal_profile = F

  # Gaussian temporal envelope centred at 25 fs, sigma = 10 fs
  t_profile = gauss(time, 25 * femto, 10 * femto)

  polarisation = 0.0
  phase = 0.0
end:laser

begin:output
  dt_snapshot = 10 * femto
  grid = always
  ey = always
end:output

# =====================================================================
# Test 3 (3D) — Gaussian beam, PROFILE-ONLY comparison: ANALYTICAL run
# ---------------------------------------------------------------------
# 3D counterpart of Test 1. Native separable Gaussian on the (y,z) plane:
#   profile = gauss(y,0,w0) * gauss(z,0,w0),  w0 = 3 um
# The matching "numerical" run injects the same 2D (y,z) envelope from a
# spatial_profile.dat. phase = 0 (no wavefront curvature in this test).
#
# Viking upgrade: 30 cells/wavelength (nx=300, ny=nz=480) on a
# 10 um (x) x 16 um (y) x 16 um (z) box. This is the expensive test;
# to scale down, reduce ny=nz or the transverse box. To scale up to
# 40 cells/wavelength use nx=400, ny=nz=640.
# =====================================================================

begin:control
  nx = 300
  ny = 480
  nz = 480

  x_min = -5 * micron
  x_max = -x_min
  y_min = -8 * micron
  y_max = -y_min
  z_min = -8 * micron
  z_max = -z_min

  t_end = 50 * femto
  stdout_frequency = 10
end:control

begin:boundaries
  bc_x_min = simple_laser
  bc_x_max = open
  bc_y_min = periodic
  bc_y_max = periodic
  bc_z_min = periodic
  bc_z_max = periodic
end:boundaries

begin:constant
  lambda0 = 1 * micron
  w0 = 3 * micron
end:constant

begin:laser
  boundary = x_min
  intensity_w_cm2 = 1.0e20
  lambda = lambda0

  # Separable Gaussian spatial profile on (y,z)
  profile = gauss(y, 0, w0) * gauss(z, 0, w0)

  # Gaussian temporal envelope centred at 25 fs, sigma = 10 fs
  t_profile = gauss(time, 25 * femto, 10 * femto)

  polarisation = 0.0
  phase = 0.0
end:laser

begin:output
  dt_snapshot = 10 * femto
  grid = always
  ey = always
end:output

# =====================================================================
# Test 1 (2D) — Gaussian beam, PROFILE-ONLY comparison: NUMERICAL run
# ---------------------------------------------------------------------
# Same beam as the analytical run, but the spatiotemporal amplitude
# envelope E(y,t) is injected from temporal_spatial_profile.dat via the
# custom injector. The analytical paraxial phase is kept identical, so
# any difference from the analytical run reflects the injection path
# (file read + bilinear interpolation), not the physics.
#
# Generate the .dat first:  python generate_profile.py
# (writes temporal_spatial_profile.dat into this directory)
# =====================================================================

begin:constant

  lambda0 = 1.0 * micron
  pulse_FWHM = 2 * micron
  pulse_tau = 15 * femto                 # pulse duration (sigma)

  w_0 = pulse_FWHM / 1.665               # beam waist at focus

  intens = 1e22                          # W/cm^2
  a0 = 8.5e-4 * sqrt(intens * lambda0^2)

  pulse_defocus = 10 * micron
  x_spot = pulse_defocus

  x_R = pi * w_0^2 / lambda0
  RC = x_spot * (1.0 + (x_R/x_spot)^2)
  w_bnd = w_0 * sqrt( 1.0 + (x_spot/x_R)^2)
  gouy = atan(x_spot/x_R)
end:constant

begin:control
  nx = 1750
  ny = 1250

  nsteps = -1
  t_end = 200 * femto

  x_min = -20 * micro
  x_max = 15 * micro
  y_min = -12.5 * micro
  y_max = 12.5 * micro

  dt_multiplier = 0.9
  dlb_threshold = 0.8
  use_random_seed = T
  stdout_frequency = 100
end:control

begin:boundaries
  bc_x_min = simple_laser
  bc_x_max = open
  bc_y_min = open
  bc_y_max = open
end:boundaries

begin:laser
  boundary = x_min
  intensity_w_cm2 = intens * (w_0 / w_bnd)^2
  lambda = lambda0

  phase = 2.0 * pi / lambda0 * y^2 / (2.0 * RC) - gouy
  pol = 0

  # Custom spatiotemporal amplitude envelope from file
  use_custom_profile = T
  use_spatiotemporal_profile = T
  profile_data_file = temporal_spatial_profile.dat
end:laser

begin:subset
  name = Defect_Region
  x_min = 10 * micron
  x_max = 15 * micron
  y_min = -7 * micron
  y_max = 7 * micron
end:subset

begin:output
  use_offset_grid = F
  dt_snapshot = 10.0e-15
  full_dump_every = -1
  force_final_to_be_restartable = F
  force_first_to_be_restartable = F

  grid = always
  ex = always
  ey = always + Defect_Region
  bz = always
  poynt_flux = always
  total_energy_sum = always
end:output

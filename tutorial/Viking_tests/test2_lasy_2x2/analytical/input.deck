# =====================================================================
# Test 2 (2D) — LASY 2x2 experiment: ANALYTICAL (built-in gauss)
# ---------------------------------------------------------------------
# Sanity anchor for the 2x2. Native gauss() profile + analytical phase.
# Should match the hand-written "numerical" reference to the
# discretisation floor (~0.02 %), confirming the reference is trustworthy.
#
# 2x2 design (amplitude source x phase source), reference = numerical:
#   numerical                : analytical amp  + analytical (deck) phase
#   lasy_amp_deck_phase      : LASY amp        + analytical (deck) phase
#   numerical_amp_lasy_phase : analytical amp  + LASY (file) phase
#   lasy                     : LASY amp        + LASY (file) phase
#
# Paraxial regime: pulse_FWHM = 10 um -> w0 ~ 6 um (~6 lambda).
# Viking upgrade: 40 cells/wavelength (nx=2800, ny=2000).
# =====================================================================

begin:constant
  lambda0 = 1.0 * micron
  pulse_FWHM = 10 * micron
  pulse_tau = 15 * femto
  w_0 = pulse_FWHM / 1.665
  intens = 1e22
  a0 = 8.5e-4 * sqrt(intens * lambda0^2)
  pulse_defocus = 10 * micron
  x_spot = pulse_defocus
  x_R = pi * w_0^2 / lambda0
  RC = x_spot * (1.0 + (x_R/x_spot)^2)
  w_bnd = w_0 * sqrt( 1.0 + (x_spot/x_R)^2)
  gouy = atan(x_spot/x_R)
end:constant

begin:control
  nx = 2800
  ny = 2000
  nsteps = -1
  t_end = 250 * femto
  x_min = -40 * micro
  x_max = 30 * micro
  y_min = -25 * micro
  y_max = 25 * micro
  dt_multiplier = 0.9
  dlb_threshold = 0.8
  use_random_seed = T
  stdout_frequency = 100
end:control

begin:boundaries
  bc_x_min = simple_laser
  bc_x_max = open
  bc_y_min = open
  bc_y_max = open
end:boundaries

begin:laser
  boundary = x_min
  intensity_w_cm2 = intens * (w_0 / w_bnd)^2
  lambda = lambda0
  phase = 2.0 * pi / lambda0 * y^2 / (2.0 * RC) - gouy
  pol = 0

  use_custom_profile = F
  profile = gauss(y, 0, w_bnd)
  t_profile = gauss(time, 3*pulse_tau, pulse_tau)
  t_start = 0
  t_end = 6*pulse_tau
end:laser

begin:output
  use_offset_grid = F
  dt_snapshot = 10.0e-15
  full_dump_every = -1
  force_final_to_be_restartable = F
  force_first_to_be_restartable = F
  grid = always
  ey = always
  total_energy_sum = always
end:output
